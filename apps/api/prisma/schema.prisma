generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Waitlist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist")
}

model User {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String                   @unique
  phone                   String?                  @unique
  passwordHash            String                   @map("password_hash")
  dateOfBirth             DateTime                 @map("date_of_birth")
  kycTier                 Int                      @default(1) @map("kyc_tier")
  isSimulationMode        Boolean                  @default(false) @map("is_simulation_mode")
  onboardingComplete      Boolean                  @default(false) @map("onboarding_complete")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @default(now()) @updatedAt @map("updated_at")
  primaryGoal             String?                  @map("primary_goal")
  firstName               String
  lastName                String                   
  userName                String                   @unique
  accountNumber           String?                  @unique
  transferPin             String?                  @map("transfer_pin")
  anchorAccountId         String?                  @map("anchor_account_id")
  anchorCustomerId        String?                  @map("anchor_customer_id")
  fcmToken                String?                  @map("fcm_token")
  profilePicture          String?                  @map("profile_picture")
  aiInsights              AIInsight[]
  bankRecipients          BankRecipient[]
  emergencyUnlockRequests EmergencyUnlockRequest[]
  kycRecords              KycRecord[]
  notifications           Notification[]
  p2pRecipients           P2PRecipient[]
  referrals               Referral[]               @relation("ReferrerReferrals")
  savingsGoals            SavingsGoal[]
  transactions            Transaction[]
  walletSplitConfig       WalletSplitConfig?
  wallets                 Wallet[]

  @@map("users")
}

model KycRecord {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tier       Int
  bvnHash    String?   @map("bvn_hash")
  ninHash    String?   @map("nin_hash")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_records")
}

model Wallet {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String                   @map("user_id") @db.Uuid
  type                    WalletType
  balance                 Decimal                  @default(0.00) @db.Decimal(12, 2)
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @default(now()) @updatedAt @map("updated_at")
  emergencyUnlockRequests EmergencyUnlockRequest[]
  transactions            Transaction[]
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("wallets")
}

model Transaction {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  walletId         String            @map("wallet_id") @db.Uuid
  type             TransactionType
  amount           Decimal           @db.Decimal(12, 2)
  reason           String?
  anchorRef        String?           @unique @map("anchor_ref")
  splitGroupId     String?           @map("split_group_id") @db.Uuid
  status           TransactionStatus @default(pending)
  createdAt        DateTime          @default(now()) @map("created_at")
  receiverWalletId String?           @map("receiver_wallet_id") @db.Uuid
  reference        String            @unique
  senderWalletId   String?           @map("sender_wallet_id") @db.Uuid
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet           Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model SavingsGoal {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  title          String
  targetAmount   Decimal   @map("target_amount") @db.Decimal(12, 2)
  currentAmount  Decimal   @default(0.00) @map("current_amount") @db.Decimal(12, 2)
  deadline       DateTime?
  autoContribute Boolean   @default(false) @map("auto_contribute")
  weeklyAmount   Decimal?  @map("weekly_amount") @db.Decimal(12, 2)
  isCompleted    Boolean   @default(false) @map("is_completed")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")
  completedAt    DateTime? @map("completed_at")
  deletedAt      DateTime? @map("deleted_at")
  status         String    @default("ACTIVE")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("savings_goals")
}

model AIInsight {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  weekStart DateTime @map("week_start")
  summary   String
  tips      Json     @default("[]")
  warnings  Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@map("ai_insights")
}

model Referral {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrerId   String         @map("referrer_id") @db.Uuid
  refereeId    String?        @map("referee_id") @db.Uuid
  refereeEmail String?        @map("referee_email")
  creditAmount Decimal        @default(100.00) @map("credit_amount") @db.Decimal(12, 2)
  status       ReferralStatus @default(pending)
  createdAt    DateTime       @default(now()) @map("created_at")
  creditedAt   DateTime?      @map("credited_at")
  referrer     User           @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)

  @@map("referrals")
}

model WalletSplitConfig {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  spendPercent     Decimal  @map("spend_percent") @db.Decimal(5, 2)
  savingsPercent   Decimal  @map("savings_percent") @db.Decimal(5, 2)
  emergencyPercent Decimal  @map("emergency_percent") @db.Decimal(5, 2)
  flexPercent      Decimal  @map("flex_percent") @db.Decimal(5, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallet_split_configs")
}

model Notification {
  id        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String               @map("user_id") @db.Uuid
  title     String
  message   String
  category  NotificationCategory
  isRead    Boolean              @default(false) @map("is_read")
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @default(now()) @updatedAt @map("updated_at")
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model BankRecipient {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  bankCode      String   @map("bank_code")
  bankName      String   @map("bank_name")
  accountNumber String   @map("account_number")
  accountName   String   @map("account_name")
  lastSentAt    DateTime @default(now()) @map("last_sent_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountNumber])
  @@index([userId])
  @@map("bank_recipients")
}

model P2PRecipient {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  recipientUserId    String   @map("recipient_user_id") @db.Uuid
  recipientFirstName String   @map("recipient_first_name")
  recipientLastName  String   @map("recipient_last_name")
  recipientUserName  String   @map("recipient_username")
  lastSentAt         DateTime @default(now()) @map("last_sent_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recipientUserId])
  @@index([userId])
  @@map("p2p_recipients")
}

model EmergencyUnlockRequest {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String                @map("user_id") @db.Uuid
  walletId    String                @map("wallet_id") @db.Uuid
  reason      String
  requestedAt DateTime              @default(now()) @map("requested_at")
  unlocksAt   DateTime              @map("unlocks_at")
  status      EmergencyUnlockStatus @default(pending)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet      Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([walletId])
  @@map("emergency_unlock_requests")
}

enum EmergencyUnlockStatus {
  pending
  completed
}

enum WalletType {
  spend
  savings
  emergency
  flex
}

enum TransactionType {
  deposit
  withdrawal
  transfer
  split_credit
  fee
  referral_credit
  goal_completion
  internal_transfer
}

enum TransactionStatus {
  pending
  success
  failed
}

enum ReferralStatus {
  pending
  credited
  expired
}

enum NotificationCategory {
  TRANSACTION
  GOAL
  SECURITY
  SYSTEM
  PROMOTION
}
